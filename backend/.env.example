NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=foodheaven_db

# Auth0 (required in production for order/payment APIs)
AUTH0_DOMAIN=dev-5k6wn3xfw6lvzvkj.us.auth0.com
AUTH0_AUDIENCE=https://api.foodheaven.app

# Server-to-server only — never expose in the browser
INTERNAL_API_TOKEN=replace_with_strong_token

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Local dev JWT (dev-token route only; disabled when NODE_ENV=production)
JWT_SECRET=replace_with_jwt_secret
JWT_EXPIRES_IN=1h
DEV_AUTH_KEY=replace_with_dev_auth_key

LOG_LEVEL=info
